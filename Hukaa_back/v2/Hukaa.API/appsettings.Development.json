    "Validation": {
      "ValidateIssuer": true,
      "ValidateAudience": true,
      "ValidateLifetime": true,
      "ValidateSigningKey": true
    },
    "RefreshToken": {
      "RotateOnUse": true,
      "RevokeOnReuse": true
    }
  }
}

