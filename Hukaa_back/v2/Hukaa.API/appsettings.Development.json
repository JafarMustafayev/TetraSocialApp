{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "ConnectionStrings": {
    "SqlServerConnectionString": "Server=localhost\\SQLEXPRESS;Database=Hukaa_v2;Trusted_Connection=True;TrustServerCertificate=True;",
    "RedisConnectionString": ""
  },
  "IdentityConfigOptions": {
    "Password": {
      "RequireDigit": false,
      "RequireLowercase": false,
      "RequireUppercase": false,
      "RequireNonAlphanumeric": false,
      "RequiredLength": 6,
      "RequiredUniqueChars": 0
    },
    "User": {
      "RequireUniqueEmail": true,
      "AllowedUserNameCharacters": "abcdefghijklmnopqrstuvwxyzABCDEFGHIJKLMNOPQRSTUVWXYZ0123456789-._"
    },
    "SignIn": {
      "RequireConfirmedEmail": true,
      "RequireConfirmedAccount": false,
      "RequireConfirmedPhoneNumber": false
    },
    "Lockout": {
      "DefaultLockoutTimeSpan": "00:15:00",
      "MaxFailedAccessAttempts": 5,
      "AllowedForNewUsers": true
    }
  },
  "ValidationRulesOptions": {
    "Auth": {
      "Login": {
        "EmailOrUsername": {
          "Required": true,
          "MinLength": 2,
          "MaxLength": 64
        },
        "Password": {
          "Required": true,
          "MinLength": 8,
          "MaxLength": 64
        }
      },
      "Register": {
        "FirstName": {
          "Required": false
        },
        "LastName": {
          "Required": false
        },
        "DateOfBirth": {
          "Required": true
        },
        "UserName": {
          "Required": true,
          "MinLength": 2,
          "MaxLength": 64
        },
        "Email": {
          "Required": true,
          "MinLength": 5,
          "MaxLength": 64
        },
        "Password": {
          "Required": true,
          "MinLength": 8,
          "MaxLength": 64
        }
      }
    }
  },
  "TokenOptions": {
    "SecurityKey": "your-very-strong-secret-key-here",
    "Jwt": {
      "Issuer": "HukaaApp",
      "Audience": "HukaaAppUsers",
      "ClockSkew": "00:01:00"
    },
    "Lifetime": {
      "AccessToken": "00:15:00",
      "RefreshToken": "7.00:00:00",
      "ConfirmationToken": "1.00:00:00"
    },
    "Validation": {
      "ValidateIssuer": true,
      "ValidateAudience": true,
      "ValidateLifetime": true,
      "ValidateSigningKey": true
    },
    "RefreshToken": {
      "RotateOnUse": true,
      "RevokeOnReuse": true
    }
  }
}

