{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "IdentityOptions": {
    "Password": {
      "RequireDigit": false,
      "RequireLowercase": false,
      "RequireUppercase": false,
      "RequireNonAlphanumeric": false,
      "RequiredLength": 6,
      "RequiredUniqueChars": 0
    },
    "User": {
      "RequireUniqueEmail": true,
      "AllowedUserNameCharacters": "abcdefghijklmnopqrstuvwxyzABCDEFGHIJKLMNOPQRSTUVWXYZ0123456789-._"
    },
    "SignIn": {
      "RequireConfirmedEmail": true,
      "RequireConfirmedAccount": false,
      "RequireConfirmedPhoneNumber": false
    },
    "Lockout": {
      "DefaultLockoutTimeSpan": "00:15:00",
      "MaxFailedAccessAttempts": 5,
      "AllowedForNewUsers": true
    }
  },
  "ValidationOptions": {
    "Auth": {
      "Login": {
        "EmailOrUsername": {
          "Required": true,
          "MinLength": 2,
          "MaxLength": 64
        },
        "Password": {
          "Required": true,
          "MinLength": 6,
          "MaxLength": 64
        }
      },
      "Register": {
        "FirstName": {
          "Required": true
        },
        "LastName": {
          "Required": true
        },
        "DateOfBirth": {
          "Required": true,
          "MustBePast": true
        },
        "UserName": {
          "Required": true,
          "MinLength": 2,
          "MaxLength": 64
        },
        "Email": {
          "Required": true,
          "MinLength": 5,
          "MaxLength": 64
        },
        "Password": {
          "Required": true,
          "MinLength": 6,
          "MaxLength": 64
        }
      }
    },
    "TwoFactor": {
      "Code": {
        "MinLength": 6,
        "MaxLength": 6
      },
      "ChallengeId": {
        "Required": true,
        "MinLength": 6,
        "MaxLength": 64
      },
      "RecoveryCode": {
        "Required": true,
        "MinLength": 6,
        "MaxLength": 64
      },
      "Password": {
        "Required": true,
        "MinLength": 6
      }
    }
  },
  "BusinessRulesOptions": {
    "Session": {
      "MaxActiveSessionsPerUser": 5,
      "RevokeOldestSessionWhenLimitExceeded": true,
      "AllowMultipleSessionsFromSameDevice": false
    }
  },
  "AllowedHosts": "*"
}
